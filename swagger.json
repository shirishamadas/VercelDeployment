{
  "openapi": "3.0.0",
  "info": {
    "title": "Node.js Swagger Vercel API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/hello": {
      "get": {
        "summary": "Returns a hello message",
        "responses": {
          "200": {
            "description": "A hello message",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/echo": {
      "post": {
        "summary": "Echoes back posted data",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Echoed data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "received": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
